                    },
                    {
                      "text": "🔄 Regenerate",
                      "additionalFields": {
                        "callbackData": "=regenerate:{{ $json.draftId }}"
                      }
                    },
                    {
                      "text": "❌ Cancel",
                      "additionalFields": {
                        "callbackData": "=cancel:{{ $json.draftId }}"
                      }
                    }
                  ]
                }
