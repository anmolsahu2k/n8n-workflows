    {
      "parameters": {
        "jsCode": "const old = $('Route Action').first().json;\nconst newDraftId = Date.now().toString(36) + Math.random().toString(36).substring(2, 5);\nconst post = $input.first().json.stdout.trim();\nconst staticData = $getWorkflowStaticData('global');\nstaticData.drafts = staticData.drafts || {};\nstaticData.drafts[newDraftId] = { idea: old.idea, post, status: 'pending', createdAt: new Date().toISOString() };\nif (staticData.drafts[old.draftId]) {\n  staticData.drafts[old.draftId] = { ...staticData.drafts[old.draftId], status: 'superseded', updatedAt: new Date().toISOString() };\n}\nreturn [{ json: { ...old, post, newDraftId } }];"
      },
