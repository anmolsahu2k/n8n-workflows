        "jsCode": "const { idea, chatId, draftId } = $('Extract Idea').first().json;\nconst post = $input.first().json.stdout.trim();\nconst staticData = $getWorkflowStaticData('global');\nstaticData.drafts = staticData.drafts || {};\nstaticData.drafts[draftId] = { idea, post, status: 'pending', createdAt: new Date().toISOString() };\nreturn [{ json: { idea, post, chatId, draftId } }];"
      },
